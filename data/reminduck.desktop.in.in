[Desktop Entry]
Version=1.5
Type=Application

Name=Reminduck
GenericName=Reminders
Comment=Don't forget about your stuff in an adorably annoying way
Categories=Office;
Exec=@APP_ID@ %U
Icon=@APP_ID@

Terminal=false
X-GNOME-Gettext-Domain=@APP_NAME@
X-GNOME-UsesNotifications=true
Keywords=Reminduck;Personal;Assistant;Reminders;Remember;Duck;Quack;Cute;
Actions=NewReminder;
StartupNotify=true
SingleMainWindow=true

[Desktop Action NewReminder]
Name=New reminder
Icon=list-add
Exec=@APP_ID@ --new-reminder
